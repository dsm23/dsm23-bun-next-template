    "fast-check": "4.8.0",
    "knip": "6.14.1",
    "lefthook": "2.1.8",
    "npm-run-all2": "9.0.0",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
    "oxlint-tsgolint": "0.23.0",
    "postcss": "8.5.15",
    "storybook": "10.4.0",
    "stylelint": "17.12.0",
    "stylelint-config-standard": "40.0.0",
