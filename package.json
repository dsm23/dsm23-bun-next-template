{
  "name": "dsm23-bun-next-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --bun next dev",
    "build": "bun --bun next build",
    "start": "bun --bun next start",
    "fmt": "oxfmt . --write",
    "fmt.check": "oxfmt . --check",
    "lint:js": "oxlint . --report-unused-disable-directives --max-warnings 0",
    "lint:css": "stylelint \"**/*.css\" --max-warnings 0 --allow-empty-input --cache --cache-strategy=content --cache-location=.stylelintcache",
    "lint": "run-p lint:js lint:css",
    "check-types": "bun --bun next typegen && tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest",
    "knip:hack": "bun test"
  },
  "dependencies": {
    "@base-ui/react": "1.5.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.218.0",
