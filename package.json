{
  "name": "dsm23-bun-next-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --bun next dev",
    "build": "bun --bun next build",
    "start": "bun --bun next start",
    "fmt": "oxfmt . --write",
    "fmt.check": "oxfmt . --check",
    "lint:js": "eslint \"**/*.{js,mjs,ts,tsx}\" --report-unused-disable-directives --max-warnings 0 --cache",
    "lint:md": "eslint \"**/*.md?(x)\" --report-unused-disable-directives --max-warnings 0 --cache --cache-strategy=content --cache-location=.eslintmdcache",
    "lint:css": "stylelint \"**/*.css\" --max-warnings 0 --allow-empty-input --cache --cache-strategy=content --cache-location=.stylelintcache",
    "lint": "run-p lint:js lint:css",
    "check-types": "bun --bun next typegen && ./node_modules/typescript/bin/tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:smoke": "vitest"
  },
  "dependencies": {
    "@opentelemetry/exporter-trace-otlp-http": "0.213.0",
    "@opentelemetry/resources": "2.6.0",
    "@opentelemetry/sdk-node": "0.213.0",
    "@opentelemetry/sdk-trace-node": "2.6.0",
    "@opentelemetry/semantic-conventions": "1.40.0",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-slot": "1.2.4",
    "@vercel/otel": "2.1.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.577.0",
    "next": "16.1.7",
    "next-themes": "0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "3.5.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.1",
    "@chromatic-com/storybook": "5.0.1",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@commitlint/types": "20.5.0",
    "@eslint/js": "9.39.4",
    "@happy-dom/global-registrator": "20.8.4",
    "@next/eslint-plugin-next": "16.1.7",
    "@playwright/test": "1.57.0",
    "@storybook/addon-a11y": "10.3.0",
    "@storybook/addon-docs": "10.3.0",
    "@storybook/addon-vitest": "10.3.0",
    "@storybook/nextjs-vite": "10.3.0",
    "@tailwindcss/node": "4.2.1",
    "@tailwindcss/postcss": "4.2.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/bun": "1.3.10",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/browser-playwright": "4.1.0",
    "@vitest/coverage-v8": "4.1.0",
    "dotenv": "17.3.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-mdx": "3.7.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-storybook": "10.3.0",
    "eslint-plugin-tailwind-canonical-classes": "1.3.1",
    "fast-check": "4.6.0",
    "globals": "17.4.0",
    "lefthook": "2.1.4",
    "npm-run-all2": "8.0.4",
    "oxfmt": "0.41.0",
    "postcss": "8.5.8",
    "storybook": "10.3.0",
    "stylelint": "17.4.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-order": "8.1.1",
    "stylelint-selector-bem-pattern": "4.0.1",
    "tailwindcss": "4.2.1",
    "tw-animate-css": "1.4.0",
    "typed-query-selector": "2.12.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.1",
    "vitest": "4.1.0"
  }
}
