{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "group:jsUnitTest",
    "group:vite",
    "helpers:pinGitHubActionDigestsToSemver",
    "security:openssf-scorecard",
    ":approveMajorUpdates",
    ":enableVulnerabilityAlerts",
    ":pinAllExceptPeerDependencies"
  ],
  "packageRules": [
    {
      "description": "Apply minimum release age to all relevant datasources with timestamps",
      "internalChecksFilter": "strict",
      "matchDatasources": [
        "github-releases",
        "github-tags",
        "node-version",
        "npm"
      ],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Apply minimum release age to docker datasource regardless of timestamps",
      "internalChecksFilter": "strict",
      "matchDatasources": ["docker"],
      "minimumReleaseAge": "3 days",
      "minimumReleaseAgeBehaviour": "timestamp-optional"
    },
    {
      "extends": ["packages:eslint"],
      "groupName": "eslint packages"
    },
    {
      "extends": ["packages:react"],
      "groupName": "react packages"
    },
    {
      "extends": ["packages:stylelint"],
      "groupName": "stylelint packages"
    },
    {
      "groupName": "nextjs monorepo",
      "matchPackageNames": ["@next/**", "eslint-plugin-next", "next"]
    },
    {
      "groupName": "playwright monorepo",
      "matchPackageNames": [
        "playwright",
        "playwright-core",
        "@playwright/test",
        "mcr.microsoft.com/playwright",
        "gwennlbh/playwright-bun"
      ]
    },
    {
      "groupName": "storybook monorepo",
      "matchPackageNames": [
        "@storybook/**",
        "eslint-plugin-storybook",
        "storybook"
      ]
    },
    {
      "groupName": "bun monorepo",
      "matchPackageNames": ["bun", "@types/bun", "bun-types", "oven/bun"]
    }
  ],
  "patch": {
    "rebaseWhen": "behind-base-branch"
  },
  "rebaseWhen": "conflicted",
  "osvVulnerabilityAlerts": true
}
